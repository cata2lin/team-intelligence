{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "core",
  "displayName": "Arona Core",
  "description": "Company-wide canonical capabilities shared by every employee: read-only Postgres MCP, NAS secret loading, Excel/Sheets export, shared playbooks.",
  "author": {
    "name": "Arona",
    "email": "carcucatalin@gmail.com"
  },
  "keywords": ["postgres", "sheets", "excel", "secrets", "nas"],
  "mcpServers": {
    "postgres-metrics": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/pg_mcp_launch.py", "DATABASE_URL_METRICS"]
    },
    "postgres-grandia": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/pg_mcp_launch.py", "DATABASE_URL_GRANDIA"]
    },
    "postgres-tom": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/pg_mcp_launch.py", "DATABASE_URL_TOM"]
    },
    "postgres-arona-bi": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/pg_mcp_launch.py", "DATABASE_URL_ARONA_BI"]
    },
    "postgres-scentum": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/pg_mcp_launch.py", "DATABASE_URL_SCENTUM"]
    },
    "postgres-awbprint": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/pg_mcp_launch.py", "DATABASE_URL_AWBPRINT"]
    },
    "postgres-pro": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/mcp_env_launch.py", "DATABASE_URI=DATABASE_URL_METRICS", "--", "uvx", "postgres-mcp", "--access-mode", "restricted"]
    },
    "shopify-dev": {
      "command": "npx",
      "args": ["-y", "@shopify/dev-mcp@latest"]
    },
    "klaviyo": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/mcp_env_launch.py", "PRIVATE_API_KEY=KLAVIYO_ESTEBAN_PRIVATE_KEY", "LIT:READ_ONLY=true", "--", "uvx", "klaviyo-mcp-server"]
    },
    "google-analytics": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/mcp_env_launch.py", "FILE:GOOGLE_APPLICATION_CREDENTIALS=GA4_SA_JSON", "--", "uvx", "analytics-mcp"]
    },
    "google-sheets": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/mcp_env_launch.py", "FILE:SERVICE_ACCOUNT_PATH=GA4_SA_JSON", "--", "uvx", "mcp-google-sheets"]
    },
    "search-console": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/mcp_env_launch.py", "FILE:GOOGLE_APPLICATION_CREDENTIALS=GA4_SA_JSON", "--", "npx", "-y", "mcp-server-gsc"]
    },
    "clickup": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/mcp_env_launch.py", "CLICKUP_API_KEY=CLICKUP_API_TOKEN", "CLICKUP_TEAM_ID=CLICKUP_TEAM_ID", "--", "npx", "-y", "@taazkareem/clickup-mcp-server"]
    },
    "dataforseo": {
      "command": "uv",
      "args": ["run", "--no-project", "${CLAUDE_PLUGIN_ROOT}/scripts/mcp_env_launch.py", "DATAFORSEO_USERNAME=DATAFORSEO_LOGIN", "DATAFORSEO_PASSWORD=DATAFORSEO_PASSWORD", "--", "npx", "-y", "dataforseo-mcp-server"]
    }
  }
}
